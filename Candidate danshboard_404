lts[c[\"candidate_id\"]] = int(digit)\n    return results\n\nprint(\"Qwen loaded on CPU, ready\")\n\nt0 = time.time()\nweak_sample = stratified_sample(stage2_pool, n=250)\nlabel_map   = weak_label_batch(weak_sample, batch_size=4)\n\nweak_labels = [{\"candidate_id\": cid, \"relevance_tier\": t} for cid, t in label_map.items()]\nweak_df     = pd.DataFrame(weak_labels)\nweak_df.to_csv(f\"{WORK_DIR}/weak_labels.csv\", index=False)\n\nelapsed = time.time() - t0\nprint(\n    f\"weak-labeled {len(weak_df)}/{len(weak_sample)} in {elapsed:.1f}s \"\n    f\"({elapsed/max(len(weak_sample),1):.2f}s/candidate)\"\n)\nprint(weak_df[\"relevance_tier\"].value_counts().sort_index())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-01T16:59:39.323377Z","iopub.execute_input":"2026-07-01T16:59:39.323757Z","iopub.status.idle":"2026-07-01T17:08:24.087638Z","shell.execute_reply.started":"2026-07-01T16:59:39.323732Z","shell.execute_reply":"2026-07-01T17:08:24.086854Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Cell 11 — Build feature matrix, train LGB + XGB + CatBoost rankers, cross-validate\nimport lightgbm as lgb\nimport xgboost as xgb\nfrom catboost import CatBoostRanker, Pool\nimport numpy as np\nimport pandas as pd\n\n# ── 1. Merge weak labels + trusted labels ─────────────────────────────────────\n# Trusted labels override weak ones for any candidate that appears in both.\ncombined_df = (\n    pd.concat([weak_df, trusted_df[[\"candidate_id\", \"relevance_tier\"]]], ignore_index=True)\n    .dropna(subset=[\"relevance_tier\"])\n    .astype({\"relevance_tier\": int})\n    .drop_duplicates(subset=\"candidate_id\", keep=\"last\")  # trusted wins\n)\nprint(f\"Combined label pool: {len(combined_df)} rows  |  tier distribution:\")\nprint(combined_df[\"relevance_tier\"].value_counts().sort_index())\n\n# ── 2. Build feature rows for every labeled candidate ─────────────────────────\ncand_lookup = {c[\"candidate_id\"]: c for c in candidates}\n\ndef