  \"improved\", \"designed\", \"architected\", \"founded\", \"grew\")\n\nJD_TEXT_LOWER = jd_text.lower()\n# Pull a real keyword set out of the JD itself instead of hand-typing one --\n# anything that looks like a skill token (2+ chars, alphabetic/hyphenated) and\n# also shows up somewhere in the candidate pool's skill lists.\n_all_pool_skills = {s.lower() for c in candidates for s in c.get(\"skills\", [])}\nJD_KEYWORDS = {s for s in _all_pool_skills if s in JD_TEXT_LOWER}\nprint(f\"derived {len(JD_KEYWORDS)} JD-matched skill keywords from candidate pool vocabulary\")\n\n# company/industry frequency tables -- computed once over the full eligible pool\ncompany_freq = Counter(c[\"current_company\"] for c in candidates)\nindustry_freq = Counter(c[\"current_industry\"] for c in candidates)\n\ndef seniority_score(title):\n    title = (title or \"\").lower()\n    return max([v for k, v in SENIORITY_TERMS.items() if k in title], default=2)\n\ndef make_features(c):\n    sig = c.get(\"redrob_signals\", {})\n    career = c.get(\"career_history\", [])\n\n    # ── experience / tenure ────────────────────────────────────────────────\n    tenures = [r.get(\"duration_months\", 0) for r in career]\n    avg_tenure = float(np.mean(tenures)) if tenures else 0.0\n    tenure_std = float(np.std(tenures)) if len(tenures) > 1 else 0.0\n    n_roles = len(career)\n    years_exp = c.get(\"years_of_experience\", 0)\n    career_velocity = n_roles / max(years_exp, 0.5)          # role changes per year\n    current_tenure = tenures[0] if tenures else 0\n\n    # ── skill match (grounded in the JD's own text, not a hardcoded list) ──\n    cand_skills = {s.lower() for s in c.get(\"skills\", [])}\n    overlap = cand_skills & JD_KEYWORDS\n    exact_overlap_ratio = len(overlap) / max(len(JD_KEYWORDS), 1)\n    weighted_match = sum(\n        1 for s in c.get(\"skills_detail\", [])\n        if s.get(\"name\", \"\").lower() in JD_KEYWORDS and s.get(\"proficiency\") in (\"advanced\", \"expert\")\n    )\n\n    # ── trajectory ───────────────────────────────────────────────────────\n    newest_title = career[0].get(\"title\", \"\") if career else c.get(\"current_title\", \"\")\n    oldest_title = career[-1].get(\"title\", \"\") if career else newest_title\n    scope_escalation = int(seniority_score(newest_title) > seniority_score(oldest_title))\n    industries = {r.get(\"industry\", \"\").lower() for r in career if r.get(\"industry\")}\n    domain_consistency = 1.0 / max(len(industries), 1)       # 1.0 = single-industry career\n\n    # ── text meta ───────────────────────────────────────────────────────\n    text_blob = (c.get(\"summary\", \"\") + \" \" + c.get(\"career_text\", \"\")).lower()\n    word_count = max(len(text_blob.split()), 1)\n    achievement_density = sum(text_blob.count(t) for t in ACHIEVEMENT_TERMS) / word_count\n    jd_keyword_density = sum(text_blob.count(k) for k in JD_KEYWORDS) / word_count  # trap signal\n\n    # ── categorical / encoded ──────────────────────────────────────────\n    company_tier_score = COMPANY_TIER_LOOKUP.get(c.get(\"current_company\", \"\").lower(), 0)\n    company_freq_enc = company_freq.get(c.get(\"current_company\", \"\"), 0)\n    industry_freq_enc = industry_freq.get(c.get(\"current_industry\", \"\"), 0)\n    edu_tier_score = EDU_TIER_SCORE.get(c.get(\"education_tier\"), 0)\n\n    # ── behavioral signals (existing, from redrob_signals) ─────────────\n    open_to_work = int(sig.get(\"open_to_work_flag\", False))\n    recruiter_response_rate = sig.get(\"recruiter_response_rate\", 0.0)\n    notice_period_days = sig.get(\"notice_period_days\", 90)\n    profile_completeness = sig.get(\"profile_completeness_score\", 0.0)\n    github_activity = sig.get(\"github_activity_score\", 0.0)\n    days_inactive = min(\n        (pd.Timestamp(\"2026-06-30\") - pd.to_datetime(\n            sig.get(\"last_active_date\", \"2025-01-01\"), errors=\"coerce\")).days\n        if sig.get(\"last_active_date\") else 365, 365)\n    willing_to_relocate = int(sig.get(\"willing_to_relocate\", False))\n    interview_completion = sig.get(\"interview_completion_rate\", 0.0)\n    offer_acceptance = sig.get(\"offer_acceptance_rate\", 0.0)\n    applications_30d = sig.get(\"applications_submitted_30d\", 0)\n\n    # ── interactions ────────────────────────────────────────────────────\n    rerank_score = c.get(\"rerank_score\", 0.0)\n    semantic_x_experience = rerank_score * years_exp\n    tier_x_skillmatch = company_tier_score * exact_overlap_ratio\n    tenure_x_seniority = (avg_tenure / 12) * seniority_score(newest_title)\n    engagement_composite = (recruiter_response_rate + interview_completion + offer_acceptance) / 3\n\n    # ── missing-value flags ────────────────────────────────────────────\n    missing_education = int(c.get(\"education_tier\") is None)\n    missing_summary = int(not c.get(\"summary\", \"\").strip())\n    missing_skills = int(len(c.get(\"skills\", [])) == 0)\n\n    return {\n        # existing keys -- kept as-is so cells 13b/14 don't break\n        \"rerank_score\": rerank_score,\n        \"years_exp\": years_exp,\n        \"open_to_work\": open_to_work,\n        \"recruiter_response_rate\": recruiter_response_rate,\n        \"notice_period_days\": notice_period_days,\n        \"profile_completeness\": profile_completeness,\n        \"github_activity\": github_activity,\n        \"days_inactive\": days_inactive,\n        \"num_skills\": len(c.get(\"skills\", [])),\n        \"willing_to_relocate\": willing_to_relocate,\n        \"interview_completion\": interview_completion,\n        \"offer_acceptance\": offer_acceptance,\n        \"applications_30d\": applications_30d,\n        # new: experience/tenure\n        \"avg_tenure_months\": avg_tenure, \"tenure_std\": tenure_std,\n        \"n_roles\": n_roles, \"career_velocity\": career_velocity,\n        \"current_tenure_months\": current_tenure,\n        # new: skill match\n        \"exact_overlap_ratio\": exact_overlap_ratio, \"weighted_match\": weighted_match,\n        # new: trajectory\n        \"scope_escalation\": scope_escalation, \"domain_consistency\": domain_consistency,\n        \"seniority_score\": seniority_score(newest_title),\n        # new: text meta\n        \"achievement_density\": achievement_density, \"jd_keyword_density\": jd_keyword_density,\n        # new: categorical/encoded\n        \"company_tier_score\": company_tier_score, \"company_freq_enc\": company_freq_enc,\n        \"industry_freq_enc\": industry_freq_enc, \"edu_tier_score\": edu_tier_score,\n        # new: interactions\n        \"semantic_x_experience\": semantic_x_experience, \"tier_x_skillmatch\": tier_x_skillmatch,\n        \"tenure_x_seniority\": tenure_x_seniority, \"engagement_composite\": engagement_composite,\n        # new: missing flags\n        \"missing_education\": missing_education, \"missing_summary\": missing_summary,\n        \"missing_skills\": missing_skills,\n    }\n\ndef make_features(c):\n    sig  = c.get(\"redrob_signals\", {})\n    prof = c  # already flattened by flatten_candidate()\n    return {\n        \"rerank_score\":          c.get(\"rerank_score\", 0.0),\n        \"years_exp\":             prof.get(\"years_of_experience\", 0),\n        \"open_to_work\":          int(sig.get(\"open_to_work_flag\", False)),\n        \"recruiter_response_rate\": sig.get(\"recruiter_response_rate\", 0.0),\n        \"notice_period_days\":    sig.get(\"notice_period_days\", 90),\n        \"profile_completeness\":  sig.get(\"profile_completeness_score\", 0.0),\n        \"github_activity\":       sig.get(\"github_activity_score\", 0.0),\n        \"days_inactive\": min(\n            (pd.Timestamp(\"2026-06-30\") - pd.to_datetime(\n                sig.get(\"last_active_date\", \"2025-01-01\"), errors=\"coerce\"\n            )).days if sig.get(\"last_active_date\") else 365,\n            365,\n        ),\n        \"num_skills\":            len(prof.get(\"skills\", [])),\n        \"willing_to_relocate\":   int(sig.get(\"willing_to_relocate\", False)),\n        \"interview_completion\":  sig.get(\"interview_completion_rate\", 0.0),\n        \"offer_acceptance\":      sig.get(\"offer_acceptance_rate\", 0.0),\n        \"applications_30d\":      sig.get(\"applications_submitted_30d\", 0),\n    }\n\nrows = []\nfor _, row in combined_df.iterrows():\n    cid = row[\"candidate_id\"]\n    if cid not in cand_lookup:\n        continue\n    feat = make_features(cand_lookup[cid])\n    feat[\"relevance_tier\"] = row[\"relevance_tier\"]\n    feat[\"candidate_id\"]   = cid\n    rows.append(feat)\n\n# NOTE: names below (train_df, X_train, y_train, CAT_COLS) match what cell 12 expects.\ntrain_df = pd.DataFrame(rows).set_index(\"candidate_id\")\n\n# All current features are numeric -- no string/categorical columns exist yet.\n# If you later add categorical fields (e.g. current_industry, country) to\n# make_features(), list their column names here so XGB/CatBoost handle them\n# correctly instead of erroring on non-numeric dtypes.\nCAT_COLS = []\n\nFEATURE_COLS = [c for c in train_df.columns if c != \"relevance_tier\"]\nX_train = train_df[FEATURE_COLS]\ny_train = train_df[\"relevance_tier\"]\n\nprint(f\"\\nFeature matrix: {X_train.shape}  |  target range: {y_train.min()}–{y_train.max()}\")\n\nif len(X_train) < 10:\n    print(\"WARNING: fewer than 10 labeled examples — cross-val will be noisy. \"\n          \"Add more trusted labels or increase weak_sample n.\")\n\n# ── 3. Train three rankers on all labeled data ─────────────────────────────────\n# group = [len(X_train)] means \"all rows are one query group\" for LTR\n\nlgb_ranker = lgb.LGBMRanker(\n    objective=\"lambdarank\",\n    metric=\"ndcg\",\n    n_estimators=200,\n    num_leaves=15,\n    min_child_samples=3,\n    learning_rate=0.05,\n    verbose=-1,\n)\nlgb_ranker.fit(\n    X_train, y_train,\n    group=[len(X_train)],\n    eval_set=[(X_train, y_train)],\n    eval_group=[[len(X_train)]],\n)\nprint(\"LightGBM ranker trained.\")\n\nxgb_ranker = xgb.XGBRanker(\n    objective=\"rank:pairwise\",\n    n_estimators=300,\n    learning_rate=0.05,\n    max_depth=5,\n    random_state=SEED,\n)\nxgb_ranker.fit(\n    X_train.drop(columns=CAT_COLS).fillna(-1),\n    y_train,\n    group=[len(X_train)],\n)\nprint(\"XGBoost ranker trained.\")\n\ncb_pool = Pool(X_train, y_train, cat_features=CAT_COLS, group_id=[0] * len(X_train))\ncb_ranker = CatBoostRanker(\n    iterations=300,\n    learning_rate=0.05,\n    depth=6,\n    loss_function=\"YetiRank\",\n    random_seed=SEED,\n    verbose=False,\n)\ncb_ranker.fit(cb_pool)\nprint(\"CatBoost ranker trained.\")\n\n# ── 4. Cross-validate LGB with repeated random subsampling ────────────────────\nfrom sklearn.metrics import ndcg_score as sk_ndcg\n\nN_FOLDS   = 10\nSUBSAMPLE = 0.8\n\nndcgs = []\nfor fold in range(N_FOLDS):\n    pop  = len(X_train)\n    size = min(max(int(pop * SUBSAMPLE), 2), pop)\n    idx  = np.random.RandomState(fold).choice(pop, size=size, replace=False)\n\n    X_fold = X_train.iloc[idx]\n    y_fold = y_train.iloc[idx]\n\n    preds = lgb_ranker.predict(X_fold)\n    ndcgs.append(sk_ndcg([y_fold.values], [preds]))\n\nmean_ndcg = np.mean(ndcgs)\nstd_ndcg  = np.std(ndcgs)\nprint(\n    f\"10x repeated-subsample NDCG on labeled set (LGB only):  \"\n    f\"mean={mean_ndcg:.3f}  std={std_ndcg:.3f}\"\n)\n\n# ── 5. Build feature matrix for the full stage-2 pool (used by cell 12) ───────\nfull_feat_rows = []\nfor c in stage2_pool:\n    feat = make_features(c)\n    feat[\"candidate_id\"] = c[\"candidate_id\"]\n    full_feat_rows.append(feat)\n\nfull_feat_df = pd.DataFrame(full_feat_rows).set_index(\"candidate_id\")\nfor col in FEATURE_COLS:\n    if col not in full_feat_df.columns:\n        full_feat_df[col] = 0.0\n\nprint(f\"\\nFull stage-2 feature matrix ready: {full_feat_df.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-02T12:35:25.232122Z","iopub.execute_input":"2026-07-02T12:35:25.232437Z","iopub.status.idle":"2026-07-02T12:35:27.872988Z","shell.ex